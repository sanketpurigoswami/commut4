# ──────────────────────────────────────────────
# 🔒 Secret / credentials files — NEVER commit these
# ──────────────────────────────────────────────
# Firebase config (real credentials — download from Firebase Console)
# android/app/google-services.json  ← keep the placeholder in repo, block real file via env/CI
# Uncomment the line below if you store the real file locally and don't want to commit it:
# android/app/google-services.json

# iOS Firebase config
ios/Runner/GoogleService-Info.plist

# Any local secrets file
secrets.dart
lib/secrets.dart
.env
*.env
local.properties
